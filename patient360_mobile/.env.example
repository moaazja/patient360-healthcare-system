# Patient 360 mobile — copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed.

# Base URL of the Express backend (no trailing slash beyond `/api`).
# Production deployment can override per-environment.
API_BASE_URL=http://localhost:5000/api

# `development` enables verbose logging. Set to `production` for releases.
APP_ENV=development

# Firebase Cloud Messaging — the bulk of FCM config travels via the
# native files (google-services.json / GoogleService-Info.plist), both of
# which are gitignored. Only the project id is referenced from Dart, and
# only for diagnostics (logged on initialize). Setup steps:
# lib/features/notifications/FIREBASE_SETUP.md.
FIREBASE_PROJECT_ID=
